# Optional defaults for alien-goats CLI
ALIENGOAT_NETWORK=testnet
ALIENGOAT_TESTNET_HORIZON=https://horizon-testnet.stellar.org
ALIENGOAT_MAINNET_HORIZON=https://horizon.stellar.org
ALIENGOAT_FRIENDBOT=https://friendbot.stellar.org
ALIENGOAT_ASSET_CODE=ALIENGOAT

# Reusable account values (set after running setup)
# ALIENGOAT_ISSUER_PUBLIC=G...
# ALIENGOAT_ISSUER_SECRET=S...
# ALIENGOAT_HOLDER_SECRET=S...
# ALIENGOAT_DESTINATION=G...
# ALIENGOAT_PUBLIC=G...
# ALIENGOAT_MINT_AMOUNT=1000

# Optional e2e memo defaults
# ALIENGOAT_TEST_TRUST_MEMO_TEXT=E2E trust memo
# ALIENGOAT_TEST_MINT_MEMO_HASH=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Optional Soroban e2e settings
# ALIENGOAT_E2E_SOROBAN=1
# ALIENGOAT_SOROBAN_NETWORK=testnet
# ALIENGOAT_SOROBAN_SOURCE=admin
# ALIENGOAT_SOROBAN_TOKEN_ID=C...
# Optional override; normally auto-resolved via `stellar keys address $ALIENGOAT_SOROBAN_SOURCE`
# ALIENGOAT_SOROBAN_ADMIN_ADDRESS=G...
# ALIENGOAT_SOROBAN_MAX_PER_REWARD=10
