# Production / mainnet template for alien-goats
# Copy to .env and fill with real values.

ALIENGOAT_NETWORK=mainnet
ALIENGOAT_MAINNET_HORIZON=https://horizon.stellar.org
ALIENGOAT_ASSET_CODE=ALIENGOAT

# Issuer account (required)
ALIENGOAT_ISSUER_PUBLIC=G_REPLACE_WITH_ISSUER_PUBLIC
ALIENGOAT_ISSUER_SECRET=S_REPLACE_WITH_ISSUER_SECRET

# Recipient / distribution account
ALIENGOAT_DESTINATION=G_REPLACE_WITH_DESTINATION_PUBLIC

# Amount minted when running mint without --amount
ALIENGOAT_MINT_AMOUNT=1000

# Optional: only needed if this CLI should create trustline for destination
# ALIENGOAT_HOLDER_SECRET=S_REPLACE_WITH_DESTINATION_SECRET

# Optional overrides
# ALIENGOAT_TESTNET_HORIZON=https://horizon-testnet.stellar.org
# ALIENGOAT_FRIENDBOT=https://friendbot.stellar.org
